RUSHI_COLLAB_IMAGE=ghcr.io/replace-me/rushi-collab-server:0.1.0
RUSHI_COLLAB_DOMAIN=collab.example.com
RUSHI_COLLAB_APP_PORT=8080

POSTGRES_DB=rushi_collab
POSTGRES_USER=rushi
POSTGRES_PASSWORD=change-this-postgres-password

RUSHI_JWT_SECRET=change-this-jwt-secret
RUSHI_SESSION_SECRET=change-this-session-secret

RUSHI_ENABLE_LOCAL_PROJECTS=true
RUSHI_ENABLE_COLLAB_PROJECTS=true
RUSHI_DEFAULT_PROJECT_SOURCE=local
RUSHI_DEFAULT_WORKFLOW_MODE=transcription

RUSHI_BACKUP_DIR=