{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "如是我闻",
  "version": "0.1.9",
  "identifier": "studio.lingchuang.rushi",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "如是我闻",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' asset: http://asset.localhost https://asset.localhost http://127.0.0.1:8741 ipc: http://ipc.localhost https://github.com https://objects.githubusercontent.com",
        "img-src": "'self' asset: http://asset.localhost https://asset.localhost blob: data:",
        "media-src": "'self' asset: http://asset.localhost https://asset.localhost blob:",
        "script-src": "'self'",
        "style-src": ["'self'", "https://fonts.googleapis.com"],
        "font-src": ["'self'", "data:", "https://fonts.gstatic.com"]
      },
      "devCsp": {
        "default-src": "'self'",
        "connect-src": "'self' asset: http://asset.localhost https://asset.localhost http://127.0.0.1:8741 http://localhost:1421 ws://localhost:1421 ipc: http://ipc.localhost https://github.com https://objects.githubusercontent.com",
        "img-src": "'self' asset: http://asset.localhost https://asset.localhost blob: data:",
        "media-src": "'self' asset: http://asset.localhost https://asset.localhost blob:",
        "script-src": ["'self'", "'unsafe-inline'"],
        "style-src": ["'self'", "https://fonts.googleapis.com"],
        "style-src-attr": "'unsafe-inline'",
        "font-src": ["'self'", "data:", "https://fonts.gstatic.com"]
      },
      "assetProtocol": {
        "enable": true,
        "scope": {
          "requireLiteralLeadingDot": false,
          "allow": [
            "$APPDATA/**/*",
            "$APPDATA/studio.lingchuang.rushi/**/*"
          ]
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdDQjdDNzUyNkU4RDhENzYKUldSMmpZMXVVc2UzZkZzOC9PdUxyRVpJRVYvL2lWdysyeXhTNVVtUUFnQXkzZ2dLQlkyTXlrNk0K",
      "endpoints": [
        "https://github.com/Abe-Junwei/rushi/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg"],
    "resources": [
      "resources/user-guide-zh.md",
      "resources/third-party-notices.txt",
      "resources/third-party-license-texts.txt",
      "resources/bundled-asr",
      "resources/bundled-asr-models"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
