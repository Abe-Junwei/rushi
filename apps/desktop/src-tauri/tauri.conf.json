{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "如是我闻",
  "version": "0.1.0",
  "identifier": "studio.lingchuang.rushi",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && npm run build:user-guide-pdf",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "如是我闻",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/user-guide-zh.md",
      "resources/user-guide-zh.pdf",
      "resources/bundled-asr"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
