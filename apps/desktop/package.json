{
  "name": "@rushi/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:user-guide-pdf": "bash ../../scripts/build-user-guide-pdf.sh",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
