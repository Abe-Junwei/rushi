    "test:e2e": "playwright test",
    "check:doc-links": "node ../../scripts/check-internal-doc-links.mjs",
    "tauri": "tauri",
    "prepare": "husky"
  },
  "dependencies": {
    "@rushi/wasm-waveform": "*",
    "@tauri-apps/api": "^2",
    "react": "^19.1.0",
