{
  "name": "@rushi/desktop",
  "private": true,
  "version": "0.1.9",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:user-guide-pdf": "bash ../../scripts/build-user-guide-pdf.sh",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:asr": "PW_ASR_MOCK_WEBSERVER=1 PW_ASR_BASE_URL=http://127.0.0.1:18741 PW_ASR_MOCK_PORT=18741 playwright test --project=asr-api",
    "test:e2e:desktop": "PW_DESKTOP_WEBSERVER=1 playwright test --project=desktop-ui",
    "check:doc-links": "node ../../scripts/check-internal-doc-links.mjs",
    "tauri": "bash ../../scripts/tauri-cli.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "waveform-data": "^4.5.2",
    "wavesurfer.js": "^7.12.10",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.18",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.1",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.0.3",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.3.1",
    "@tauri-apps/cli-win32-x64-msvc": "^2.11.2",
    "lightningcss-win32-x64-msvc": "^1.32.0"
  }
}
