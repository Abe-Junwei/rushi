{
  "name": "@rushi/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:user-guide-pdf": "bash ../../scripts/build-user-guide-pdf.sh",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:asr": "PW_ASR_MOCK_WEBSERVER=1 PW_ASR_BASE_URL=http://127.0.0.1:18741 PW_ASR_MOCK_PORT=18741 playwright test --project=asr-api",
    "test:e2e:desktop": "PW_DESKTOP_WEBSERVER=1 playwright test --project=desktop-ui",
    "check:doc-links": "node ../../scripts/check-internal-doc-links.mjs",
    "tauri": "tauri",
    "prepare": "husky"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "lucide-react": "^1.20.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "waveform-data": "^4.5.2",
    "wavesurfer.js": "^7.12.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.61.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.2",
    "@tailwindcss/postcss": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
