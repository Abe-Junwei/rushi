{
  "schema_version": "1",
  "segments": [
    {
      "start_sec": 0.23,
      "end_sec": 0.85,
      "text": "没关系，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 0.87,
      "end_sec": 1.705,
      "text": "我讲两句，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 3.29,
      "end_sec": 8.18,
      "text": "我们这一次的入学入学教育啊，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 8.44,
      "end_sec": 9.965,
      "text": "这个地方有讲到位，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 10.65,
      "end_sec": 11.15,
      "text": "三个班，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 11.15,
      "end_sec": 13.81,
      "text": "同时一起做很仓促，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 14.030000000000001,
      "end_sec": 15.01,
      "text": "你们人手也不够。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 15.47,
      "end_sec": 16.23,
      "text": "一开始规矩，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 16.23,
      "end_sec": 27.835,
      "text": "你们都没有学好注意到穿鞋的时候脚不能离地一坐，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 28.97,
      "end_sec": 30.095,
      "text": "要么是盘坐，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 31.470000000000002,
      "end_sec": 32.39,
      "text": "要么是挂座，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 32.47,
      "end_sec": 34.77,
      "text": "也就是我们这个禅堂给你们开许，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 34.81,
      "end_sec": 35.89,
      "text": "允许你们挂座，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 36.410000000000004,
      "end_sec": 37.63,
      "text": "知道很多人坐不住，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 37.71,
      "end_sec": 39.675000000000004,
      "text": "因为我们不是以修订为主，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 40.75,
      "end_sec": 45.415,
      "text": "没有必要让大家在这里好好的龇牙铃嘴。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 50.01,
      "end_sec": 53.955,
      "text": "但是不能以此作为放映的入口，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 56.1,
      "end_sec": 56.955,
      "text": "腿功不好，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 58.980000000000004,
      "end_sec": 60.7,
      "text": "如果从修订的角度来说，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 60.92,
      "end_sec": 62.52,
      "text": "肯定是有一定障碍的。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 62.800000000000004,
      "end_sec": 65.08,
      "text": "但是从修觉性的角度来说，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 65.38,
      "end_sec": 68.88,
      "text": "是没有影响行住坐卧都可以修。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 69.32000000000001,
      "end_sec": 75.27,
      "text": "但是坐要有坐向挂座，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 75.35000000000001,
      "end_sec": 76.27,
      "text": "我们是教了的，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 76.45,
      "end_sec": 77.29,
      "text": "怎么挂座？",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 77.87,
      "end_sec": 87.19500000000001,
      "text": "盘座我们也教了我们盘座这一座如果是盘坐盘到底中间不要动。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 90.08,
      "end_sec": 91.48,
      "text": "如果是挂作，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 92.04,
      "end_sec": 93.565,
      "text": "一开始你就画作，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 94.34,
      "end_sec": 97.22,
      "text": "大家也不要尝试去学他们挂座。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 97.3,
      "end_sec": 98.52,
      "text": "你你们结束以后，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 98.52,
      "end_sec": 102.625,
      "text": "你们可以问问他们挂座的也不好说，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 105.61,
      "end_sec": 110.89,
      "text": "不管是挂座还是盘做有一个基本的准则。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 111.11,
      "end_sec": 112.69500000000001,
      "text": "就是你们在做的时候，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 113.7,
      "end_sec": 116.805,
      "text": "在做的时候腰要挺起来，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 117.89,
      "end_sec": 127.68,
      "text": "腰要提起来这个这个上垫它是一个斜斜着的一个垫子腿，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 127.68,
      "end_sec": 128.445,
      "text": "做好的，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 129.31,
      "end_sec": 130.495,
      "text": "往前坐一坐，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 133.91,
      "end_sec": 137.13,
      "text": "新手稍稍往后坐一坐，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 137.19,
      "end_sec": 139.59,
      "text": "但是不要靠椅背椅背。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 140.07,
      "end_sec": 141.37,
      "text": "如果是长时间的，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 141.37,
      "end_sec": 145.01,
      "text": "靠一开始没有养成这个习惯，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 145.09,
      "end_sec": 146.81,
      "text": "一开始养成一个坏的习惯，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 146.95000000000002,
      "end_sec": 148.17000000000002,
      "text": "是揪不过来的。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 148.79,
      "end_sec": 153.21,
      "text": "长时间的这样去靠着坐这个腰就废了。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 153.71,
      "end_sec": 155.29500000000002,
      "text": "所以很多人生啥病，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 156.08,
      "end_sec": 161.925,
      "text": "过去这个散堂里面很多人生散病就是这么来的。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 163.63,
      "end_sec": 168.135,
      "text": "挂坐的时候坐好腰提起来，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 169.54,
      "end_sec": 170.935,
      "text": "脊柱拎起来，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 173.39000000000001,
      "end_sec": 177.895,
      "text": "上身的身姿的要求是跟大家讲过的，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 181.15,
      "end_sec": 184.71,
      "text": "要做一做就做到底啊，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 184.81,
      "end_sec": 186.085,
      "text": "我们的要求也不高。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 187.65,
      "end_sec": 187.89000000000001,
      "text": "好，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 188.05,
      "end_sec": 250.975,
      "text": "请上桌提交售后脊柱区分，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 257.11,
      "end_sec": 267.13,
      "text": "肩背雄鹰向两翼两侧舒展舒展。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 267.45,
      "end_sec": 269.915,
      "text": "注意到我们这里呢不讲挺胸，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 271.04,
      "end_sec": 273.57,
      "text": "不讲挺胸啊，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 274.21,
      "end_sec": 275.13,
      "text": "不讲挺胸，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 275.51,
      "end_sec": 280.92,
      "text": "也不讲八背是书展两翼自然的舒展。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 280.94,
      "end_sec": 281.56,
      "text": "这个舒展，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 281.58,
      "end_sec": 282.825,
      "text": "它不是景绷，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 283.86,
      "end_sec": 287.04,
      "text": "也不是放松自然的舒展，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 287.14,
      "end_sec": 289.935,
      "text": "像是小鸟将飞未飞的样子，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 291.24,
      "end_sec": 291.86,
      "text": "没去体会。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 291.86,
      "end_sec": 297.225,
      "text": "你肩部肩背舒展，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 303.42,
      "end_sec": 306.875,
      "text": "走部有提时，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 311.92,
      "end_sec": 316.83,
      "text": "手机定义男同胞，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 316.83,
      "end_sec": 317.63,
      "text": "左手在下，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 318.27,
      "end_sec": 318.89,
      "text": "女同胞，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 318.89,
      "end_sec": 324.415,
      "text": "右手在下拇指轻触而后分开一厘米，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 330.14,
      "end_sec": 336.685,
      "text": "头面中正脸喉贴紧，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 355.26,
      "end_sec": 371.935,
      "text": "学生端正安稳，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 407.33,
      "end_sec": 408.255,
      "text": "调整屏页，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 415.53000000000003,
      "end_sec": 428.395,
      "text": "止息内在的言辞互动去确定调整呼吸，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 435.78000000000003,
      "end_sec": 441.205,
      "text": "让呼吸神慢了，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 442.52,
      "end_sec": 447.15500000000003,
      "text": "戏长何缓，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 511.46000000000004,
      "end_sec": 518.465,
      "text": "异业调整检查。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 519.19,
      "end_sec": 519.57,
      "text": "此刻，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 519.57,
      "end_sec": 527.995,
      "text": "内在的心里念头是否有不正面、",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 529.6,
      "end_sec": 532.875,
      "text": "不善变杂念、",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 533.67,
      "end_sec": 534.165,
      "text": "恶念、",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 534.77,
      "end_sec": 536.135,
      "text": "邪业忘名。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 538.9,
      "end_sec": 539.44,
      "text": "有的话，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 539.72,
      "end_sec": 553.24,
      "text": "通通扫除检查。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 556.94,
      "end_sec": 557.3000000000001,
      "text": "此刻，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 557.3000000000001,
      "end_sec": 564.205,
      "text": "心神的状态唤醒度如何、",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 568.47,
      "end_sec": 569.4250000000001,
      "text": "活力如何，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 574.3000000000001,
      "end_sec": 575.165,
      "text": "力量如何。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 580.92,
      "end_sec": 582.075,
      "text": "内在语言提示，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 589.01,
      "end_sec": 589.895,
      "text": "我在打坐，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 594.79,
      "end_sec": 595.855,
      "text": "我在山丘，",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 599.53,
      "end_sec": 606.22,
      "text": "我要专注的认真的大火。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
      "start_sec": 606.22,
      "end_sec": 621.205,
      "text": "这一座这一座我们要补充一些知识课的内容。",
      "confidence": null,
      "low_confidence": true,
      "detail": null,
      "kind": "speech"
    },
    {
