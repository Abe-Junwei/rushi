{
  "name": "rushi",
  "private": true,
  "description": "如是我闻 — 本地中文转写与校对（独立仓）",
  "workspaces": ["apps/desktop"],
  "scripts": {
    "prepare": "cd apps/desktop && husky",
    "check:doc-links": "node scripts/check-internal-doc-links.mjs",
    "desktop:dev": "bash scripts/desktop-dev.sh",
    "desktop:build": "bash scripts/release-cleanup-dmg-staging.sh && npm run tauri build -w @rushi/desktop && bash scripts/stage-release-artifacts.sh",
    "desktop:build-app": "bash scripts/release-sidecar-preflight.sh && bash scripts/release-cleanup-dmg-staging.sh && npm run tauri build -w @rushi/desktop -- --bundles app && bash scripts/stage-release-artifacts.sh",
    "desktop:build-app:local": "bash scripts/build-desktop-local-hand-test.sh",
    "desktop:build-dmg": "bash scripts/release-sidecar-preflight.sh && bash scripts/release-cleanup-dmg-staging.sh && npm run tauri build -w @rushi/desktop -- --bundles dmg && bash scripts/stage-release-artifacts.sh",
    "desktop:open-release-app": "open \"apps/desktop/src-tauri/target/release/bundle/macos/如是我闻.app\"",
    "release:sidecar-preflight": "bash scripts/release-sidecar-preflight.sh",
    "release:waveform-probe": "bash scripts/waveform-release-probe.sh",
    "release:postbuild-verify": "bash scripts/release-postbuild-verify.sh",
    "release:mac": "bash scripts/v1-personal-release-build.sh",
    "release:win": "powershell -ExecutionPolicy Bypass -File scripts/v1-windows-release-build.ps1",
    "lint": "npm run lint -w @rushi/desktop",
    "test": "npm run test -w @rushi/desktop",
    "typecheck": "npm run typecheck -w @rushi/desktop",
    "build": "npm run build -w @rushi/desktop",
    "test:all": "npm run test && npm run asr:test && cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "p0:acceptance": "bash scripts/p0-acceptance.sh",
    "eval:placeholders": "bash scripts/eval-generate-placeholders.sh",
    "eval:run": "python3 scripts/eval-run.py",
    "eval:run:hotwords-ab": "python3 scripts/eval-run.py --hotwords-ab --filter-id d3-tang32-zhikong-gaijiang --format csv",
    "eval:run:hotwords-on": "python3 scripts/eval-run.py --hotwords-mode on --filter-id d3-tang32-zhikong-gaijiang",
    "eval:run:long-form": "python3 scripts/eval-run.py --filter-id d3-tang32-zhikong-gaijiang --assert-min-segments",
    "asr:dev": "bash scripts/run-asr-dev.sh",
    "asr:test": "bash scripts/run-asr-pytest.sh",
    "desktop:test:e2e": "npm run test:e2e -w @rushi/desktop",
    "desktop:test:e2e:asr": "npm run test:e2e:asr -w @rushi/desktop",
    "desktop:test:e2e:desktop": "npm run test:e2e:desktop -w @rushi/desktop",
    "asr:build-sidecar-unix": "bash scripts/build-asr-sidecar-unix.sh",
    "asr:stage-bundled-models": "bash scripts/stage-bundled-asr-models.sh",
    "asr:preflight-bundled-models": "bash scripts/preflight-bundled-asr-models.sh",
    "asr:bootstrap": "bash scripts/bootstrap-asr-venv.sh",
    "asr:smoke-sidecar": "bash scripts/smoke-asr-sidecar-health.sh",
    "asr:build-sidecar-windows-cpu": "powershell -ExecutionPolicy Bypass -File scripts/build-asr-sidecar-windows.ps1",
    "asr:build-sidecar-windows-cuda": "powershell -ExecutionPolicy Bypass -File scripts/build-asr-sidecar-windows.ps1 -Variant Cuda",
    "asr:regen-sidecar-locks": "bash scripts/regen-sidecar-cpu-lock.sh && bash scripts/regen-sidecar-cuda-win-lock.sh",
    "design:add": "npx --yes getdesign@latest add",
    "clean:artifacts": "bash scripts/clean-dev-artifacts.sh"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  }
}
